# .env.example — скопіюйте у .env і заповніть реальними даними
# Файл .env НЕ комітиться у Git (він у .gitignore)

# Адреса 1С HTTP-сервісу. Формат: https://<сервер>/<база>/hs/gsk
# де <база> — псевдонім інфобази у публікації, gsk — кореневий URL сервісу.
# Точна специфікація методів — у файлі API_1C_CONTRACT.md (контракт v2)
EXPO_PUBLIC_1C_BASE_URL=https://192.168.1.100/gsk_base/hs/gsk

# Технічний користувач публікації (Basic Auth на рівні веб-сервера).
# Власник авторизується ОКРЕМО — за телефоном+OTP (Bearer-токен). Ці поля
# потрібні лише якщо публікація вимагає Basic Auth і його не знімає reverse-proxy.
EXPO_PUBLIC_1C_TECH_USER=gsk_service
EXPO_PUBLIC_1C_TECH_PASS=your_password_here

# Режим: true = mock дані (код підтвердження в демо: 1234), false = реальний 1С
EXPO_PUBLIC_USE_MOCK=true
